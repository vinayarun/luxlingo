  "sentences": [
    {
      "sentence_id": "sent_001",
      "text_lu": "De Kaffi ass waarm.",
      "text_en": "The coffee is warm.",
      "sense_ids": [
        "s_kaffi_1",
        "s_sinn_is_1",
        "s_waarm_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_002",
      "text_lu": "De Kaffi gëtt waarm.",
      "text_en": "The coffee becomes warm.",
      "sense_ids": [
        "s_kaffi_1",
        "s_ginn_become_1",
        "s_waarm_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_003",
      "text_lu": "Ech sinn do.",
      "text_en": "I am there.",
      "sense_ids": [
        "s_ech_1",
        "s_sinn_are_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_004",
      "text_lu": "Ech iesse Brout.",
      "text_en": "I eat bread.",
      "sense_ids": [
        "s_ech_1",
        "s_iessen_1",
        "s_brout_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_005",
      "text_lu": "Brout ass gutt.",
      "text_en": "Bread is good.",
      "sense_ids": [
        "s_brout_1",
        "s_sinn_is_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_006",
      "text_lu": "Merci fir de Kaffi.",
      "text_en": "Thank you for the coffee.",
      "sense_ids": [
        "s_merci_1",
        "s_kaffi_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_007",
      "text_lu": "Ech drénke Kaffi.",
      "text_en": "I drink coffee.",
      "sense_ids": [
        "s_ech_1",
        "s_drenken_1",
        "s_kaffi_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_008",
      "text_lu": "Ech sinn hei.",
      "text_en": "I am here.",
      "sense_ids": [
        "s_ech_1",
        "s_sinn_are_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_009",
      "text_lu": "Ech si frou.",
      "text_en": "I am happy.",
      "sense_ids": [
        "s_ech_1",
        "s_sinn_are_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_010",
      "text_lu": "Merci, ech si gutt.",
      "text_en": "Thank you, I am good.",
      "sense_ids": [
        "s_merci_1",
        "s_ech_1",
        "s_sinn_are_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_011",
      "text_lu": "De Brout gëtt kal.",
      "text_en": "The bread becomes cold.",
      "sense_ids": [
        "s_brout_1",
        "s_ginn_become_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_012",
      "text_lu": "Ech ginn midd.",
      "text_en": "I become tired.",
      "sense_ids": [
        "s_ech_1",
        "s_ginn_become_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_013",
      "text_lu": "Merci fir alles.",
      "text_en": "Thank you for everything.",
      "sense_ids": [
        "s_merci_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {

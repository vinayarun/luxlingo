    {
      "sentence_id": "sent_187",
      "text_lu": "Wéi geet et Dir?",
      "text_en": "How are you doing? (formal)",
      "sense_ids": [
        "s_wei_1",
        "s_goen_geet_1",
        "s_et_1",
        "s_dir_formal"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_188",
      "text_lu": "Et geet.",
      "text_en": "It goes (I am okay).",
      "sense_ids": [
        "s_et_1",
        "s_goen_geet_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_189",
      "text_lu": "Dat geet gutt.",
      "text_en": "That goes well.",
      "sense_ids": [
        "s_dat_1",
        "s_goen_geet_1",
        "s_gutt_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_190",
      "text_lu": "Moie, wéi geet et du?",
      "text_en": "Hello, how are you doing?",
      "sense_ids": [
        "s_moien_1",
        "s_wei_1",
        "s_goen_geet_1",
        "s_et_1",
        "s_du_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_191",
      "text_lu": "Ech gesinn Iech.",
      "text_en": "I see you (formal).",
      "sense_ids": [
        "s_ech_1",
        "s_iech"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_192",
      "text_lu": "Ech verstoen Iech.",
      "text_en": "I understand you (formal).",
      "sense_ids": [
        "s_ech_1",
        "s_verstoen_1",
        "s_iech"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_193",
      "text_lu": "Wat soen ech Iech?",
      "text_en": "What do I say to you?",
      "sense_ids": [
        "s_wat_1",
        "s_ech_1",
        "s_iech"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_194",
      "text_lu": "Ech merci Iech.",
      "text_en": "I thank you.",
      "sense_ids": [
        "s_ech_1",
        "s_merci_1",
        "s_iech"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_195",
      "text_lu": "Wéi heescht Dir haut?",
      "text_en": "What is your name today?",
      "sense_ids": [
        "s_wei_1",
        "s_heeschen_1",
        "s_dir_formal"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_196",
      "text_lu": "Ech heeschen net du, ech heeschen Dir.",
      "text_en": "I am not called du, I am called Dir.",
      "sense_ids": [
        "s_ech_1",
        "s_heeschen_1",
        "s_net_1",
        "s_du_1",
        "s_dir_formal"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_197",
      "text_lu": "Lues a gutt.",
      "text_en": "Slowly and well.",
      "sense_ids": [
        "s_lues_1",
        "s_an_1",
        "s_gutt_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_198",
      "text_lu": "Lues, wannechgelift.",
      "text_en": "Slowly, please.",
      "sense_ids": [
        "s_lues_1",
        "s_wannechgelift_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_199",
      "text_lu": "Wat heescht dat op Lëtzebuergesch?",
      "text_en": "What does that mean in Luxembourgish?",
      "sense_ids": [
        "s_wat_1",
        "s_heeschen_1",
        "s_dat_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_200",
      "text_lu": "Mir geet et haut midd.",
      "text_en": "I am feeling tired today.",
      "sense_ids": [
        "s_mir_dat",
        "s_goen_geet_1",
        "s_et_1",
        "s_midd_1"
      ],
      "cloze_index": 3,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_201",
      "text_lu": "Iech merci.",
      "text_en": "Thank you.",
      "sense_ids": [
        "s_iech",
        "s_merci_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_202",
      "text_lu": "Ech gesinn Iech net.",
      "text_en": "I do not see you (formal).",
      "sense_ids": [
        "s_ech_1",
        "s_net_1",
        "s_iech"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_203",
      "text_lu": "Verstinn Dir Iech?",
      "text_en": "Do you understand each other?",
      "sense_ids": [
        "s_verstoen_1",
        "s_dir_formal",
        "s_iech"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_204",
      "text_lu": "Mir geet et haut lues.",
      "text_en": "I am going slowly today.",
      "sense_ids": [
        "s_mir_dat",
        "s_goen_geet_1",
        "s_et_1",
        "s_lues_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_205",
      "text_lu": "Geet et Mir?",
      "text_en": "Is it for me?",
      "sense_ids": [
        "s_goen_geet_1",
        "s_et_1",
        "s_mir_dat"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_206",
      "text_lu": "Wat geet Mir?",
      "text_en": "What is for me?",
      "sense_ids": [
        "s_wat_1",
        "s_goen_geet_1",
        "s_mir_dat"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_207",
      "text_lu": "Mäi Numm geet Mir gutt.",
      "text_en": "My name goes well for me.",
      "sense_ids": [
        "s_main_1",
        "s_numm_1",
        "s_goen_geet_1",
        "s_mir_dat",
        "s_gutt_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_208",
      "text_lu": "Ass dat fir Mir?",
      "text_en": "Is that for me? (fir is new, wait)",
      "sense_ids": [
        "s_sinn_is_1",
        "s_dat_1",
        "s_mir_dat"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_zoah_glue_0",
      "text_lu": "Ech si mat Dir.",
      "text_en": "I am with you.",
      "sense_ids": [
        "s_ech_1",
        "s_sinn_is_1",
        "s_mat_1",
        "s_dir_formal"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_zoah_glue_1",
      "text_lu": "Brout mat Kaffi.",
      "text_en": "Bread with coffee.",
      "sense_ids": [
        "s_brout_1",
        "s_mat_1",
        "s_kaffi_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_zoah_glue_2",
      "text_lu": "Kaffi ouni Mëllech.",
      "text_en": "Coffee without milk.",
      "sense_ids": [
        "s_kaffi_1",
        "s_ouni_1",
        "s_mellech_1"
      ],
      "cloze_index": 1,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_zoah_glue_3",
      "text_lu": "Dat ass ganz gutt.",
      "text_en": "That is very good.",
      "sense_ids": [
        "s_dat_1",
        "s_sinn_is_1",
        "s_ganz_1",
        "s_gutt_1"
      ],
      "cloze_index": 2,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    },
    {
      "sentence_id": "sent_zoah_glue_4",
      "text_lu": "Wann Dir verstitt.",
      "text_en": "If you (formal) understand.",
      "sense_ids": [
        "s_wann_1",
        "s_dir_formal",
        "s_verstoen_1"
      ],
      "cloze_index": 0,
      "lex_coverage": 1.0,
      "syn_density": 1,
      "is_handcrafted": true
    }
